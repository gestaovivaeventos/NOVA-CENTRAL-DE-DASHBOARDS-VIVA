{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "turbo run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- ':(exclude)docs/**' ':(exclude)scripts/**' ':(exclude)*.md' ':(exclude).gitignore' ':(exclude).vscode/**'",
  "functions": {
    "src/pages/api/analise-mercado/inep.ts": {
      "maxDuration": 60,
      "memory": 512
    },
    "src/pages/api/analise-mercado/franquias.ts": {
      "maxDuration": 60
    },
    "src/pages/api/vendas/sales.ts": {
      "maxDuration": 30
    },
    "src/pages/api/vendas/funil.ts": {
      "maxDuration": 30
    },
    "src/pages/api/vendas/fundos.ts": {
      "maxDuration": 30
    },
    "src/pages/api/vendas/metas.ts": {
      "maxDuration": 30
    }
  }
}

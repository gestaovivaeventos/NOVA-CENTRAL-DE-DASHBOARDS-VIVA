/*
 * TRABALHAR COM DROPZONE GENERICAMENTE (MODIFICADO PARA TRABALHAR NO PORTAL :/)
 *
 * previewNode: Área de trabalho do Dropzone,
 * clickable: Referencia do botão que vai chamar o Dropzone,
 * acceptedFiles: Tipo de arquivos aceitos,
 * maxFileSize: Tamanho maximo de cada arquivo (MB),
 * thumbnailWidth: Largura da miniatura,
 * thumbnailHeight: Altura da miniatura
 * maxFiles: Quantidade maxima de arquivos aceitos,
 * uploadMultiple: Aceita mais de um download ao mesmo tempo?,
 * previewsContainer: Onde vai mostrar os arquivos que serão upados, será a visualização dos mesmos,
 * uploadprogress: Trabalhar com barra de progresso,
 * successmultiple: O que fazer depois que os arquivos forem upados,
 * removedfile: Ao clicar no nome do arquivo (para excuir) é chamada essa função,
 * error: Retorna o erro personalizado,

 * RETORNAR{ 1°: O PROPRIO OBJETO DROPZONE, 2° ARRAY COM AS INFORMAÇÕES DOS ARQUIVOS (QUE JÁ FORAM PROCESSADOS PELO SERVIDOR)}
 */
function masterDropzone(json) {
    var files = [];

    var previewNode = (json.previewNode == null) ? $('.template') : json.previewNode;
    var previewTemplate = previewNode.parent().html();

    var objDropzone = new Dropzone((json.clickable == null) ? '.dz-clickable' : json.clickable, { // Make the whole body a dropzone
        url: (json.url == null) ? '/vbGeneric/upload' : json.url, // Set the url
        acceptedFiles: (json.acceptedFiles == null) ? ".bmp,.gif,.jpeg,.jpg,.png,.pdf,.doc,.docx,.xls,.xlsx,.txt" : json.acceptedFiles,
        paramName: "file",
        maxFilesize: (json.maxFilesize == null) ? 10 : json.maxFilesize,
        thumbnailWidth: (json.thumbnailWidth == null) ? 80 : json.thumbnailWidth, //Largura da miniatura
        thumbnailHeight: (json.thumbnailHeight == null) ? 80 : json.thumbnailHeight, //Altura da miniatura
        parallelUploads: 10,
        maxFiles: (json.maxFiles == null) ? 20 : json.maxFiles,
        uploadMultiple: true,
        progressbarId: (json.progressbarId == null) ? progressbar = '.progress-bar' : progressbar = json.progressbarId,
        previewTemplate: previewTemplate,
        autoQueue: (json.autoQueue == null) ? true : json.autoQueue, // Make sure the files aren't queued until manually added
        autoProcessQueue: (json.autoProcessQueue == null) ? true : json.autoQueue,
        previewsContainer: (json.previewsContainer == null) ? '.previews' : json.previewsContainer,// Define the container to display the previews
        dictFileTooBig: '{"mensagemError": "O arquivo possui: {{filesize}}MiB. O tamanho máximo é de: {{maxFilesize}}MiB."}',
        dictInvalidFileType: '{"mensagemError": "Tipo do arquivo não é suportado"}',
        //accept: json.accept,//Antes de fazer o upload
        uploadprogress: (json.uploadprogress == null) ? function (file, progress) {
            //criar uma progresbar para carregar
            var progressBar = $(progressbar);
            progressBar.text((parseInt(progress) - 40) + '%');
            progressBar.css('width', (parseInt(progress) - 40) + '%');
        }
            : json.uploadprogress,

        successmultiple: (json.successmultiple == null) ? function (file, response) {
            $.each(response, function (index, value) {
                files.push(value);
            });
            var progressBar = $(progressbar);
            progressBar.text('100%');
            progressBar.css('width', '100%');
            return msgRetornoAjax('Arquivos validados com sucesso', 'success');
        }
            : json.successmultiple,

        removedfile: (json.removedfile == null) ? function (file, serverFileName) {
            //Remover na view
            $(file.previewElement).remove();
            //Não estou confiando no javascript, ele ta fazendo alguma confusão e retornando o array vazio no foreach
            // estou alocando o array em outra variável por seguranças
            $(progressbar).css('width', '0%').text('');

            var filesComparacao = files;
            $.each(filesComparacao, function (index, value) {
                if (value != null) {
                    //(file.name == value.originalFile) ? delete files[index] : null;
                    (file.name == value.originalFile) ? files.splice(index, 1) : null;
                }
            });
        } : json.removedfile,

        error: (json.error == null) ? function (file, res) {
            var message = res.split(':');
            if (res == 'You can not upload any more files.') {
                msgRetornoAjax('Só é permitido anexar um arquivo por vez!', "error");
            } else {
                var message = message[1];
                message = message.replace('\"}', '').replace('\"', '');
                msgRetornoAjax(message, "error");
            }


            return this.removeFile(file);
        }
            : json.error
    });
    return {'objDropzone': objDropzone, 'files': files}
}

/**
 * @param obj
 * @returns {boolean}
 */
function compareDateNow(obj, now) {
    var dataLimite = obj.split('-');
    var notHora = dataLimite[2].split(' ');
    return (parseInt(dataLimite[0] + dataLimite[1] + notHora[0]) < parseInt(now));
//        return false;
}

function maskInteger(v) {
    return v.replace(/\D/g, "");
}

function moneyToBr(valor) {
    var valorBr = valor.toString().replace('.', ',');
    return valorBr;
}
function currencyBrToFloat(valor) {

    while (valor.indexOf('.') >= 0) {
        valor = valor.replace('.', '');
    }

    valor = valor.replace(',', '.');

    return parseFloat(valor) || 0;
}

/**
 * Validar CPF e CNPJ
 * @param json
 */
function validarCpfCnpj(json) {
    return $(json.el).cpfcnpj({
        mask: true,
        validate: json.type,
        event: (json.event == null) ? 'keyup' : json.event,
        handler: json.handler == null ? '' : json.handler,
        ifValid: (json.ifValid == null) ? function (input) {
            input.css('border-color', 'green');
        } : json.ifValid,
        ifInvalid: (json.ifInvalid == null) ? function (input) {
            input.css('border-color', 'red');
            $(json.el).focus();
        } : json.ifInvalid
    });
}

/**
 * Valida um email diretamente no input.
 * Só fazer a chamada onKeyUp="validateEmailInput(input);" e ver a mágica acontecer
 * @param input
 */
function validateEmailInput(input) {
    var element = $(input);
    if (IsEmail(element.val())) {
        element.css('border-color', 'green');
        element.attr('valid', true);
        element.removeClass("erroEmail");
    } else {
        element.css('border-color', 'red');
        element.attr('valid', false);
        element.addClass("erroEmail");
    }
}
/**
 * Carregar Datepicker
 * @param el1
 */
function loadDate(el) {
    $(el).mask("99/99/9999");
    $(el).datepicker({
        dateFormat: 'dd/mm/yy',
        language: 'pt-BR',
        dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
        monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
    });
}

/**
 * Validar email passado
 * @param email
 * @returns {boolean}
 * @constructor
 */
function IsEmail(email) {
    //var re = /^(([^<>()\[\]\\.,;:\s@"]+(\.[^<>()\[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
    var validator = /^([\w\.\-]+)@([\w\-]+)((\.(\w){2,30})+)$/i;
    return validator.test(email);
}

function validarCNPJ(cnpj) {

    cnpj = cnpj.replace(/[^\d]+/g, '');

    if (cnpj == '') return false;

    if (cnpj.length != 14)
        return false;

    // Elimina CNPJs invalidos conhecidos
    if (cnpj == "00000000000000" ||
        cnpj == "11111111111111" ||
        cnpj == "22222222222222" ||
        cnpj == "33333333333333" ||
        cnpj == "44444444444444" ||
        cnpj == "55555555555555" ||
        cnpj == "66666666666666" ||
        cnpj == "77777777777777" ||
        cnpj == "88888888888888" ||
        cnpj == "99999999999999")
        return false;

    // Valida DVs
    tamanho = cnpj.length - 2
    numeros = cnpj.substring(0, tamanho);
    digitos = cnpj.substring(tamanho);
    soma = 0;
    pos = tamanho - 7;
    for (i = tamanho; i >= 1; i--) {
        soma += numeros.charAt(tamanho - i) * pos--;
        if (pos < 2)
            pos = 9;
    }
    resultado = soma % 11 < 2 ? 0 : 11 - soma % 11;
    if (resultado != digitos.charAt(0))
        return false;

    tamanho = tamanho + 1;
    numeros = cnpj.substring(0, tamanho);
    soma = 0;
    pos = tamanho - 7;
    for (i = tamanho; i >= 1; i--) {
        soma += numeros.charAt(tamanho - i) * pos--;
        if (pos < 2)
            pos = 9;
    }
    resultado = soma % 11 < 2 ? 0 : 11 - soma % 11;
    if (resultado != digitos.charAt(1))
        return false;

    return true;

}
function validarCPF(cpf) {
    cpf = cpf.replace(/[^\d]+/g, '');
    if (cpf == '') return false;
    // Elimina CPFs invalidos conhecidos
    if (cpf.length != 11 ||
        cpf == "00000000000" ||
        cpf == "11111111111" ||
        cpf == "22222222222" ||
        cpf == "33333333333" ||
        cpf == "44444444444" ||
        cpf == "55555555555" ||
        cpf == "66666666666" ||
        cpf == "77777777777" ||
        cpf == "88888888888" ||
        cpf == "99999999999")
        return false;
    // Valida 1o digito
    add = 0;
    for (i = 0; i < 9; i++)
        add += parseInt(cpf.charAt(i)) * (10 - i);
    rev = 11 - (add % 11);
    if (rev == 10 || rev == 11)
        rev = 0;
    if (rev != parseInt(cpf.charAt(9)))
        return false;
    // Valida 2o digito
    add = 0;
    for (i = 0; i < 10; i++)
        add += parseInt(cpf.charAt(i)) * (11 - i);
    rev = 11 - (add % 11);
    if (rev == 10 || rev == 11)
        rev = 0;
    if (rev != parseInt(cpf.charAt(10)))
        return false;
    return true;
}

/**
 * Busca os fundos da unidade do usuário, aceita nome do fundo ou id, convert para json o retorno
 *
 * @returns {{url: string, dataType: string, type: string, delay: number, data: Function, processResults: Function}}
 */
function selectFundoJsonAjax(url, subselectView = null) {
    return {
        url: url,
        dataType: 'json',
        type: 'POST',
        delay: 800,
        data: function (params) {
            return {
                valorParametro: params.term, // search term
                subselectView: subselectView//retornar os subselects
                //page: params.page
            };
        },
        processResults: function (data, page) {
            var more = data.length;
            var results = [];
            $.each(data, function (index, item) {
                results.push({
                    id: JSON.stringify(item),
                    text: 'Unidade: ' + item.nomeUnidade + '| Fundo: ' + item.nomeFundo + ' | Código: ' + item.idFundo
                });
            });
            return {
                results: results
            };
        }
    };
}
/**
 * Busca os leadFundos da unidade do usuário, aceita nome do leadFundos ou id, convert para json o retorno
 *
 * @returns {{url: string, dataType: string, type: string, delay: number, data: Function, processResults: Function}}
 */
function selectLeadFundoJsonAjax(url, subselectView = null) {
    return {
        url: url,
        dataType: 'json',
        type: 'POST',
        delay: 500,
        data: function (params) {
            return {
                param: params.term,// search term
                vinculados: "true",// search term
                subselectView: subselectView//retornar os subselects
            };
        },
        processResults: function (data, page) {
            var more = data.length;
            var results = [];
            $.each(data, function (index, item) {
                results.push({
                    id: JSON.stringify(item),
                    text: 'Turma: ' + item.nome + ' | Código: ' + item.id
                });
            });
            return {
                results: results
            };
        }
    };
}

function loadDivUnidadeDisponivelFranqueadora(idFranqueadora, nomeFranqueadora) {
    //remover o load da franqueadora
    $('.removeUnidade span[data-id = ' + idFranqueadora + ']').closest('.unidadeTag').remove();
    // carregar Franqueadora
    if ($('input[name="disponivelPara"]:checked').val() == 3) {
        setTimeout(function () {
            $('input[name=disponivelPara][value="3"]').change();
        }, 1)

    }
    $('input[name=disponivelPara]').on('change', function () {

        if ($(this).val() == 3) {
            if ($('.unidadePrincipal').length == 0) {
                var div = $(this).closest('.divUnidadeDisponivel');
                div.find('.painelUnidades').append(
                    '<div class="btn-group unidadePrincipal">' +
                    '    <button type="button" class="btn btn-xs btn-inverse nome" id="unidadePrincipal">' + nomeFranqueadora + '</button>' +
                    '</div>'
                );
            }

        } else {
            $('.unidadeTag,.unidadePrincipal').remove();
        }
    });

}
/**
 *
 * @param json [url, data, success = null]
 */
function genericAjax(json) {
    $.ajax({
        url: json.url,
        type: 'POST',
        data: json.data,
        success: (!json.success) ? function (data) {
            msgRetornoAjax(data.retorno, 'success');
        } : json.success,
        error: (!json.error) ? function (error) {
            modalError(error);
        } : json.error
    })
}
/**
 *
 * @param date
 */
function isValidDate(dateString) {
    var regEx = /^(?:(?:31(\/|-|\.)(?:0?[13578]|1[02]))\1|(?:(?:29|30)(\/|-|\.)(?:0?[1,3-9]|1[0-2])\2))(?:(?:1[6-9]|[2-9]\d)?\d{2})$|^(?:29(\/|-|\.)0?2\3(?:(?:(?:1[6-9]|[2-9]\d)?(?:0[48]|[2468][048]|[13579][26])|(?:(?:16|[2468][048]|[3579][26])00))))$|^(?:0?[1-9]|1\d|2[0-8])(\/|-|\.)(?:(?:0?[1-9])|(?:1[0-2]))\4(?:(?:1[6-9]|[2-9]\d)?\d{2})$/;
    if (!dateString.match(regEx))return false;
    else return true;
}
/**
 *
 * @param json {size[modal-lg, modal-sm, modal-xs, modal-md],header, body, footer}
 * @returns {string}
 */
function masterModal(json) {

    var modal = $('.modal-template');

    modal.addClass('masterModal');
    modal.attr('id', 'genericModal');

    if (json.backdrop == true) {
        modal.attr('data-backdrop', 'static');
    }

    modal.find('.modal-dialog').addClass(json.size);

    if (json.header != null | json.header != '') {
        modal.find('.modal-title').text(json.header);
    }

    modal.find('.modal-body').html((json.body != null) ? json.body : '');
    modal.find('.modal-footer').html((json.footer != null)
        ? json.footer : '<button type="button" class="btn btn-sm btn-default" data-dismiss="modal">Fechar</button>');

    $(modal).modal('toggle');
}

function modalError(error) {

    var a = $.parseJSON(error.responseText);

    var modalError =
        '<div class="modal fade modal-error" id="modalError" tabindex="-1" role="dialog" aria-labelledby="myModalLabel">' +
        '<div class="modal-dialog modal-lg">' +
        '<div class="modal-content">' +
        '<div class="modal-body">' +
        '<center><h2>Opsss, ocorreu algum erro! :/</h2></center>' +
        '<center id="mensgError"><h4>' + a.mensagemError + '</h4></center>' +
        '</div>' +
        '</div>' +
        '</div>' +
        '</div>';

    $(modalError).modal('show');
}

/**
 *
 * @param msg
 * @param classe {success, error, warning}
 */
function msgRetornoAjax(msg, classe, time) {
    var retorno;
    if (classe == "success") {
        retorno = '<strong><i class="ace-icon fa fa-check"> </i> Sucesso!</strong> ';
    }
    else if (classe == "error") {
        retorno = '<strong><i class="ace-icon fa fa-times"> </i> Erro!</strong> ';
    }
    else if (classe == "warning") {
        retorno = '<strong><i class="ace-icon fa fa-info"> </i> Atenção!</strong> ';
    }
    $.gritter.add({
        title: retorno,
        text: msg,
        sticky: false,
        fade_out_speed: 6000,
        time: (time == null) ? 6000 : time,
        class_name: 'align-left gritter-' + classe + ' gritter-light gritter-left'
    });
}

/**
 * Modal de confirmação para deleção
 * @param id
 */
function modalDelete(id, aviso) {
    var av = (aviso == true) ? "Se houver algum registro vinculado a esse, ele será deletado. Tem certeza disso?" : "Deseja realmente excluir esse item?";
    var modal = $('.modal-template');

    modal.addClass('modalDelete');
    modal.attr('id', 'modalDelete');

    modal.find('.modal-title').text(av);
    modal.find('.modal-footer').html(
        '<button type="button" class="btn btn-default" data-dismiss="modal">Não</button>' +
        '<button type="button" id="btnConfirmDelete" onclick="deleteItem(' + id + ')" class="btn btn-danger">Sim</button>'
    );

    $(modal).modal('show');
}

/**
 *
 * @param date : A string
 * @param isDateTime : Se a data passada é um DateTime
 * @param responseDateTime : Se a resposta é um DataTime
 */
function formatDataPt(data, isDateTime, responseDateTime) {
    var dataHora;
    var dataArr;
    if (isDateTime == true) {
        dataHora = data.split(" ");
        dataArr = dataHora[0].split("-");
    } else {
        dataArr = data.split("-");
    }
    return (responseDateTime == true) ? dataArr[2] + "/" + dataArr[1] + "/" + dataArr[0] + ' ' + dataHora[1] : dataArr[2] + "/" + dataArr[1] + "/" + dataArr[0];
}

function mesAnoDataPtBr(date) {
    var dataBrArr = formatDataPt(date.date, true, false).split('/');
    return dataBrArr[1] + '/' + dataBrArr[2];
}

/**
 *
 * @param date : A string
 * @param isDateTime : Se a data passada é um DateTime
 * @param responseDateTime : Se a resposta é um DataTime
 */
function formatDataBD(data, isDateTime, responseDateTime) {
    if (data == null || data == '') {
        return false;
    }
    var dataHora;
    var dataArr;
    if (isDateTime == true) {
        dataHora = data.split(" ");
        dataArr = dataHora[0].split("/");
    } else {
        dataArr = data.split("/");
    }
    return (responseDateTime == true) ? dataArr[2] + "-" + dataArr[1] + "-" + dataArr[0] + ' ' + dataHora[1] : dataArr[2] + "-" + dataArr[1] + "-" + dataArr[0];
}


//AS TRÊS PROXIMAS FUNÇÕES SÃO RSPONSÁVEIS POR VALIDAR FORMULÁRIO.
//A PRIMEIRA TRAS UMA MENSAGEM COM OS CAMPOS QUE NÃO PASSARAM
//A SEGUNDA É UM PLUGIN, FUNCIONA DE FORMA MAIS AUTOMÁTICA
//A TERCEIRA TRAS UMA MENSAGEM COM OS CAMPOS QUE NÃO PASSARAM E COLOCAR EM VERMELHO O INPUT

/**
 * @param formulario
 * @returns {string}
 */
function validaFormularioRerno(formulario) {
    var guarda = '';
    $.each(formulario.find(':required'), function (index, value) {
        if ($(value).val() == '' || $(value).val() == null) {
            guarda += $(this).closest('div').find('label').text() + '<br>';
        }
    });
    return guarda;
}

/**
 * Validar formulário de acordo com o json passado
 * @param json
 */
function validateFormulario(json) {
    $(json.formulario).validate({
        errorElement: 'div',
        errorClass: 'error-value-input',
        focusInvalid: false,
        rules: json.rules,
        messages: json.msg || 'Campo obrigatório'
    });
}

/**
 * @param formulario
 * @returns {string}
 */
function validaFormularioRetornoInput(formulario) {
    var guarda = '';
    $.each(formulario.find(':required'), function (index, value) {
        if ($(value).val() == '' || $(value).val() == null) {
            guarda += $(this).closest('div').find('label').text() + '<br>';
            $(this).css({"color": "red", "border-color": "red"});
            if ($(this).closest('div').find('#formacaoValor-error').length == 0) {
                $(this).closest('div').append('<div style="color:red" class="error-value-input formacaoValor-error">Este campo é requerido.</div>')

            }
        }
    });
    return guarda;
}
/**
 * Modal Generico
 * @param id
 */
function modalGenerico(id, msg) {
    var modal = $('.modal-template');

    modal.addClass('modalGenerico');
    modal.attr('id', 'modalGenerico');

    modal.find('.modal-title').text(msg);
    modal.find('.modal-footer').html(
        '<button type="button" class="btn btn-sm btn-default" data-dismiss="modal">Não</button>' +
        '<button type="button" id="' + id + '" class="btn btn-sm btn-danger">Sim</button>'
    );

    $(modal).modal('show');
}

/**
 * Função usada pelo Drop List Multiple da biblioteca select2
 * Busca as unidades e cria uma tag personalizada no campo
 * Aceita nome do fundo ou id
 *
 * @returns {{url: string, dataType: string, type: string, delay: number, data: Function, processResults: Function}}
 */
 function selectUnidadeAjax(url) {
  return {
    url: url,
    dataType: 'json',
    type: 'POST',
    delay: 500,
    data: function (params) {
      return {
        valorParametro: params.term // parametro de procura
      };
    },
    processResults: function (data) {
      var results = [];
      $.each(data, function (index, item) {
        results.push({
          id: item.id,
          text: 'Unidade: ' + item.nome + ' | Código: ' + item.id
        });
      });
      return {
        results: results
      };
    }
  };
}

/**
 * Busca os fundos da unidade do usuário, aceita nome do fundo ou id
 *
 * @returns {{url: string, dataType: string, type: string, delay: number, data: Function, processResults: Function}}
 */
function selectFundoAjax(url) {
    return {
        url: url,
        dataType: 'json',
        type: 'POST',
        delay: 500,
        data: function (params) {
            return {
                valorParametro: params.term // search term
                //page: params.page
            };
        },
        processResults: function (data, page) {
            var more = data.length;
            var results = [];
            $.each(data, function (index, item) {
                results.push({
                    id: item.idFundo,
                    text: 'Fundo: ' + item.nomeFundo + ' | Código: ' + item.idFundo
                });
            });
            return {
                results: results
            };
        }
    };
}

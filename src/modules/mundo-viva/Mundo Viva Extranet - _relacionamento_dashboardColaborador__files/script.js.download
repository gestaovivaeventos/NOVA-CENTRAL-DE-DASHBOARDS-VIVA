/**
 *
 * @param url
 * @returns {{url: *, dataType: string, type: string, delay: number, data: Function, processResults: Function}}
 */
function selectUsuarioAjax(url, unidade) {
    var arrayElement = {unidade: unidade};
    return {
        url: url,
        dataType: 'json',
        type: 'POST',
        delay: 500,
        data: function (params) {
            return {
                valorParametro: params.term,
                outherParam: arrayElement
                //page: params.page
            };
        },
        processResults: function (data, page) {
            var more = data.length;
            var results = [];

            $.each(data, function (index, item) {
                results.push({
                    id: item.id,
                    text: item.nome
                });
            });

            return {
                results: results
            };
        }
    };
}

/**
 * Esse autocomplete é muito usado em todoo ERP_VIVA, por isso é legal defini-lo aqui. Mudei a rota para poder usar o twig e não ter que mudar
 * o controller de fundo (melhor não arriscar)
 */
function autocompleteFundo(rota, unidade = null) {
    autocompleteMaster(
        {
            url: rota,
            success: function (item) {
                return {
                    label: item['nomeFundo'],
                    id: item['idFundo']
                }
            },
            data: unidade
        }
    )
}

/**
 * Auto complete geral, com ele só é preciso ter um atributo data-autocomplete no campo e uma classe autocomplete
 * @param obj
 * @returns {boolean}
 */
function autocompleteMaster(obj) {

    obj.target = ("target" in obj) ? obj.target : '.autocomplete';
    if ($(obj.target).val() == '') {
        return false;
    }
    $(obj.target).autocomplete({
        source: function (request, response) {
            $.ajax({
                url: obj.url,
                dataType: "json",
                type: 'POST',
                data: {
                    valorParametro: request.term,
                    outherParam: (obj.data) ? obj.data : null
                },
                success: function (data) {
                    response($.map(data, obj.success));
                }
            })
        },
        select: function (event, ui) {
            $(obj.target).attr('data-autocomplete', ui.item.id);
        },
        delay: obj.delay || 600,
        max: obj.max || 15,
        scrollHeight: obj.scrollHeight || 50,
        autoFocus: obj.autoFocus || true,
        minLength: obj.minLenght || 1
    });
}

function selectedDuallist() {
    $('body').on('click', '.list-group .list-group-item', function () {
        $(this).toggleClass('active');
    });
}

function buttonDuallist() {
    $('.list-arrows button').click(function () {
        var $button = $(this), actives = '';
        if ($button.hasClass('move-left')) {
            actives = $('.list-right ul li.active');
            actives.removeClass('active');
            actives.clone().appendTo('.list-left ul');
            actives.remove();
        } else if ($button.hasClass('move-right')) {
            actives = $('.list-left ul li.active');
            actives.removeClass('active');
            actives.clone().appendTo('.list-right ul');
            actives.remove();
        }
    });

}

function selectAllDuallist() {
    $('.dual-list .selector').click(function () {
        var $checkBox = $(this);
        if (!$checkBox.hasClass('selected')) {
            $checkBox.addClass('selected').closest('.well').find('ul li:not(.active)').addClass('active');
            $checkBox.children('i').removeClass('glyphicon-unchecked').addClass('glyphicon-check');
        } else {
            $checkBox.removeClass('selected').closest('.well').find('ul li.active').removeClass('active');
            $checkBox.children('i').removeClass('glyphicon-check').addClass('glyphicon-unchecked');
        }
    });
}

function searchDuallist() {
    $('[name="SearchDualList"]').keyup(function (e) {
        var $rows = $(this).closest('.dual-list').find('.list-group li');
        var val = $.trim($(this).val()).replace(/ +/g, ' ').toLowerCase();
        $rows.show().filter(function () {
            var text = $(this).text().replace(/\s+/g, ' ').toLowerCase();
            return !~text.indexOf(val);
        }).hide();
    });
}

/**
 *
 * @param valor
 * @returns {string}
 */
function formatarParaReais(valor) {
    if (valor === null || $.trim(valor) == '') {
        valor = 0;
    }
    if (typeof valor == "number") {
        valor = valor.toFixed(2);
    }

    if (!(valor instanceof String)) {
        valor = valor.toString();
    }
    valor = valor.replace('.', ',');
    return valor;

}

function formatMoneyRealParaNumber(texto) {
    var textoFormato = texto.split(".").join("");
    textoFormato = textoFormato.replace(",", ".");
    var valor = parseFloat(textoFormato);
    return valor;
}

function formatFloatToBr(valorFloat, thousandSeparator = '.', decimalSeparator = ',', showMoeda = false) {

    var valorDirty = formatarParaReais(valorFloat).replace('R$', '');
    var valorArr = valorDirty.split(',');
    var parteInteira = valorArr[0].replace(/\B(?=(\d{3})+(?!\d))/g, thousandSeparator);
    var parteDecimal = valorArr[1];

    return (showMoeda ? 'R$ ' : '') + parteInteira + decimalSeparator + parteDecimal;
}

function removeParam(key, sourceURL) {
    var rtn = sourceURL.split("?")[0];
    window.history.pushState("", "", rtn);
    return rtn;
}


/**
 * CRIA UM JSON COM BASE NO FORMUL¡RIO (OU ALGUM HTML QUE CONTENHA INPUTS, SELECTS E ETC)
 * Created by viva-ti on 17/01/2017.
 */

var RETURN;

/**
 *
 * @param options {"json":default, "array", "object"}
 * @returns {*}
 */
$.fn.serializeForm = function (options) {
    switch (options) {
        case 'array':
            RETURN = this.serializeArray();
            break;
        case 'object':
            RETURN = objectForm(this);
            break;
        default :
            RETURN = JSON.stringify(objectForm(this));
            break;
    }
    return RETURN;
};

function objectForm(param) {
    var el = $(param);
    var o = {};
    var a = el.serializeArray();
    $.each(a, function () {
        if (o[this.name] !== undefined) {
            if (!o[this.name].push) {
                o[this.name] = [o[this.name]];
            }
            o[this.name].push(this.value || '');
        } else {
            o[this.name] = this.value || '';
        }
    });
    return o;
}
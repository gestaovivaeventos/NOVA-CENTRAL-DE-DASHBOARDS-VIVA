function phoneDDD(element) {
    var phone;
    $(element).unmask();
    phone = $(element).val().replace(/\D/g, "");
    phone.length > 10 ? $(element).mask("(99)99999-9999") : $(element).mask("(99)9999-99999");
}

$('a[class=".dropdown-toggle"]').click(function () {
    alert("Sign new href executed.");
});

//Mascaras
$(".cep").mask("00000-000");
$(".phone").mask("0000-0000");
$(".cpf").mask("000.000.000-00", { reverse: true });
$(".money").mask("000.000.000.000.000,00", { reverse: true });
$(".phone_ddd").mask("(99)99999-9999");
$(".phone_ddd")
    .focusout(function () {
        phoneDDD(this);
    })
    .trigger("focusout");

$(".chosen-select").chosen();

var oLoader = {
    wholeWindow: true,
    effect: "slide",
    image: '/ERP_VIVA/img/loader4.gif',
    imageBgColor: "none !important",
};

var modal = $(".modal, #genericModal");
var body = $("body");

//Modal ao carregar qualquer ajax

$(document)
    .ajaxStart(function () {
        $.when(body.oLoader(oLoader).find("#oloader_loader_0_1").css("box-shadow", "")).then(function () {
            modal.css("z-index", "99");
        });
    })
    .ajaxStop(function () {
        $.when($("#oloader_loader_0_1").is(":visible") ? body.oLoader("hide") : null).then(function () {
            modal.css("z-index", "1050");
        });
    });

$(".modal-template").on("hidden.bs.modal", function () {
    //   Ao fechar o modal eu o limpo
    var modal = $(this);
    modal.find(".modal-dialog").removeClass().addClass("modal-dialog");
    modal.removeClass().addClass("modal modal-template fade");
    modal.removeAttr("id");
    modal.removeAttr("data-backdrop", "static");
    modal.find(".modal-title").text("");
    modal.find(".modal-body > *").remove();
    modal.find(".modal-footer > *").remove();
});
/**
 * USAR NO INPUT DO CAMPO CONFORME EXEMPLO:
 * <input id="data" type="text" class="datepicker" name="data"/>
 *
 * NO JS pode ser chamado direto com .datepicker();
 */
//Converte o DATEPICKER para pt-BR
$(function ($) {
    $.datepicker.regional["pt-BR"] = {
        closeText: "Fechar",
        prevText: "&lt;Anterior",
        nextText: "Próximo&gt;",
        currentText: "Hoje",
        monthNames: [
            "Janeiro",
            "Fevereiro",
            "Março",
            "Abril",
            "Maio",
            "Junho",

            "Julho",
            "Agosto",
            "Setembro",
            "Outubro",
            "Novembro",
            "Dezembro",
        ],

        monthNamesShort: ["Jan", "Fev", "Mar", "Abr", "Mai", "Jun", "Jul", "Ago", "Set", "Out", "Nov", "Dez"],
        dayNames: ["Domingo", "Segunda-feira", "Terça-feira", "Quarta-feira", "Quinta-feira", "Sexta-feira", "Sabado"],
        dayNamesShort: ["Dom", "Seg", "Ter", "Qua", "Qui", "Sex", "Sab"],
        dayNamesMin: ["Dom", "Seg", "Ter", "Qua", "Qui", "Sex", "Sab"],
        weekHeader: "Sm",
        dateFormat: "dd/mm/yy",
        firstDay: 0,
        isRTL: false,
        showMonthAfterYear: false,
        yearSuffix: "",
    };
    $.datepicker.setDefaults($.datepicker.regional["pt-BR"]);
});
